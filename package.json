{
  "name": "wboke-api-platform",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "pnpm --filter @wboke/desktop dev",
    "dev:web": "pnpm --filter @wboke/web dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "check": "pnpm -r --if-present check && node scripts/verify-deploy.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs"
  }
}
