{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WBoke API",
  "version": "0.1.0",
  "identifier": "com.wboke.api.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WBoke API",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://www.wboke.com https://api.wboke.com; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false
  }
}
