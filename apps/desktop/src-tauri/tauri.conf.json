{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "六脉神剑API",
  "version": "0.1.0",
  "identifier": "com.wboke.api.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "六脉神剑API",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://www.wboke.com https://api.wboke.com; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "upgradeCode": "f4527afe-0331-5ddf-a8b0-8cbf4332cf73"
      }
    }
  }
}
