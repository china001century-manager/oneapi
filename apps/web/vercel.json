{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://wbokedesktop-production.up.railway.app/api"
    },
    {
      "source": "/api/:path*/",
      "destination": "https://wbokedesktop-production.up.railway.app/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/api/:path*"
    },
    {
      "source": "/v1",
      "destination": "https://wbokedesktop-production.up.railway.app/v1"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/v1/:path*"
    },
    {
      "source": "/v1beta",
      "destination": "https://wbokedesktop-production.up.railway.app/v1beta"
    },
    {
      "source": "/v1beta/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/v1beta/:path*"
    },
    {
      "source": "/dashboard",
      "destination": "https://wbokedesktop-production.up.railway.app/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/dashboard/:path*"
    },
    {
      "source": "/channels",
      "destination": "https://wbokedesktop-production.up.railway.app/channels"
    },
    {
      "source": "/channels/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/channels/:path*"
    },
    {
      "source": "/chat",
      "destination": "https://wbokedesktop-production.up.railway.app/chat"
    },
    {
      "source": "/chat/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/chat/:path*"
    },
    {
      "source": "/chat2link",
      "destination": "https://wbokedesktop-production.up.railway.app/chat2link"
    },
    {
      "source": "/chat2link/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/chat2link/:path*"
    },
    {
      "source": "/console",
      "destination": "https://wbokedesktop-production.up.railway.app/console"
    },
    {
      "source": "/console/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/console/:path*"
    },
    {
      "source": "/keys",
      "destination": "https://wbokedesktop-production.up.railway.app/keys"
    },
    {
      "source": "/keys/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/keys/:path*"
    },
    {
      "source": "/models",
      "destination": "https://wbokedesktop-production.up.railway.app/models"
    },
    {
      "source": "/models/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/models/:path*"
    },
    {
      "source": "/playground",
      "destination": "https://wbokedesktop-production.up.railway.app/playground"
    },
    {
      "source": "/playground/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/playground/:path*"
    },
    {
      "source": "/profile",
      "destination": "https://wbokedesktop-production.up.railway.app/profile"
    },
    {
      "source": "/profile/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/profile/:path*"
    },
    {
      "source": "/redemption-codes",
      "destination": "https://wbokedesktop-production.up.railway.app/redemption-codes"
    },
    {
      "source": "/redemption-codes/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/redemption-codes/:path*"
    },
    {
      "source": "/subscriptions",
      "destination": "https://wbokedesktop-production.up.railway.app/subscriptions"
    },
    {
      "source": "/subscriptions/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/subscriptions/:path*"
    },
    {
      "source": "/system-info",
      "destination": "https://wbokedesktop-production.up.railway.app/system-info"
    },
    {
      "source": "/system-info/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/system-info/:path*"
    },
    {
      "source": "/wallet",
      "destination": "https://wbokedesktop-production.up.railway.app/wallet"
    },
    {
      "source": "/wallet/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/wallet/:path*"
    },
    {
      "source": "/usage-logs",
      "destination": "https://wbokedesktop-production.up.railway.app/usage-logs"
    },
    {
      "source": "/usage-logs/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/usage-logs/:path*"
    },
    {
      "source": "/users",
      "destination": "https://wbokedesktop-production.up.railway.app/users"
    },
    {
      "source": "/users/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/users/:path*"
    },
    {
      "source": "/system-settings",
      "destination": "https://wbokedesktop-production.up.railway.app/system-settings"
    },
    {
      "source": "/system-settings/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/system-settings/:path*"
    },
    {
      "source": "/assets",
      "destination": "https://wbokedesktop-production.up.railway.app/assets"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/assets/:path*"
    },
    {
      "source": "/static",
      "destination": "https://wbokedesktop-production.up.railway.app/static"
    },
    {
      "source": "/static/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/static/:path*"
    },
    {
      "source": "/oauth",
      "destination": "https://wbokedesktop-production.up.railway.app/oauth"
    },
    {
      "source": "/oauth/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/oauth/:path*"
    },
    {
      "source": "/reset",
      "destination": "https://wbokedesktop-production.up.railway.app/reset"
    },
    {
      "source": "/reset/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/reset/:path*"
    },
    {
      "source": "/setup",
      "destination": "https://wbokedesktop-production.up.railway.app/setup"
    },
    {
      "source": "/setup/:path*",
      "destination": "https://wbokedesktop-production.up.railway.app/setup/:path*"
    },
    {
      "source": "/logo.png",
      "destination": "https://wbokedesktop-production.up.railway.app/logo.png"
    },
    {
      "source": "/favicon.ico",
      "destination": "https://wbokedesktop-production.up.railway.app/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "https://wbokedesktop-production.up.railway.app/manifest.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
